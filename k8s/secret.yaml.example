---
# Example secret for Vertex AI credentials
# Copy this file to secret.yaml and fill in your actual credentials
# DO NOT commit secret.yaml to version control!

apiVersion: v1
kind: Secret
metadata:
  name: hermes-vertex-ai
  namespace: hermes
  labels:
    app: hermes
type: Opaque
stringData:
  # Google Cloud Project ID
  VERTEX_PROJECT_ID: "your-gcp-project-id"

  # Google Cloud Service Account JSON (base64 encode the JSON file)
  # To generate: base64 -w 0 service-account-key.json
  GOOGLE_APPLICATION_CREDENTIALS_JSON: |
    {
      "type": "service_account",
      "project_id": "your-project-id",
      "private_key_id": "...",
      "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
      "client_email": "...",
      "client_id": "...",
      "auth_uri": "https://accounts.google.com/o/oauth2/auth",
      "token_uri": "https://oauth2.googleapis.com/token",
      "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
      "client_x509_cert_url": "..."
    }
