# Hermes Configuration Example
# Copy this file to .env and customize for your environment

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Hermes
APP_VERSION=1.0.0
ENVIRONMENT=development  # development|staging|production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG|INFO|WARNING|ERROR

# ============================================================================
# Server Settings
# ============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=true  # Auto-reload on code changes (development only)

# ============================================================================
# Mock Mode Flags
# ============================================================================
# MOCK_MODE: Master switch - if true, entire system uses mock data
# MOCK_AGENTS: Use canned responses instead of real Vertex AI calls
# MOCK_EXECUTION: Dry-run mode for file execution (no actual writes)

MOCK_MODE=true
MOCK_AGENTS=true
MOCK_EXECUTION=true

# ============================================================================
# Database Settings
# ============================================================================
# DATABASE_PATH=./hermes.db  # SQLite database file (default: hermes.db in project root)
# DATABASE_ECHO=false  # Echo SQL queries to console (debugging)

# ============================================================================
# Google Cloud Vertex AI Settings
# ============================================================================
# Required for real AI agent interactions (when MOCK_AGENTS=false)
# Obtain these from your Google Cloud Console

# VERTEX_PROJECT_ID=your-gcp-project-id  # REQUIRED: Your GCP project ID
# VERTEX_REGION=us-east5  # Region for Vertex AI (us-east5 recommended for Claude)
# VERTEX_MODEL=claude-sonnet-4-5@20250929  # Claude model version
# VERTEX_MAX_TOKENS=8192  # Maximum tokens per response
# VERTEX_TEMPERATURE=0.7  # Creativity level (0.0-1.0)

# ============================================================================
# File System Settings
# ============================================================================
# OUTPUT_BASE_PATH=./output  # Base directory for all generated files
# ARTIFACTS_PATH=./output/artifacts  # Code/container/deployment artifacts
# COMMUNICATIONS_PATH=./output/communications  # Emails/calendar/blog posts
# LOGS_PATH=./output/logs  # Execution logs

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_CHAT=true  # Enable chat panel functionality
ENABLE_STREAMING=true  # Enable streaming responses from agents
ENABLE_FIELD_AWARE_CHAT=false  # Enable field-aware chat (Phase 5)
ENABLE_REAL_TIME_UPDATES=false  # Enable WebSocket/SSE for progress (Phase 5)

# ============================================================================
# Security Settings
# ============================================================================
# ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000  # CORS origins

# ============================================================================
# Configuration Examples
# ============================================================================

# Example 1: Full Mock Mode (UI Development & Demos)
# Perfect for stakeholder demos and UI development
# No AI calls, no file writes, instant responses
#
# MOCK_MODE=true
# MOCK_AGENTS=true
# MOCK_EXECUTION=true

# Example 2: Real AI Testing (Prompt Development)
# Real Vertex AI agents but no actual file execution
# Good for testing agent prompts and workflows
#
# MOCK_MODE=false
# MOCK_AGENTS=false
# MOCK_EXECUTION=true
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_REGION=us-east5

# Example 3: Full Production (Live Deployment)
# Real AI + real file execution
# Use for actual prototype generation
#
# MOCK_MODE=false
# MOCK_AGENTS=false
# MOCK_EXECUTION=false
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_REGION=us-east5
# ENVIRONMENT=production
# DEBUG=false

# Example 4: OpenShift Deployment
# Production config with persistent volumes
#
# MOCK_MODE=false
# MOCK_AGENTS=false
# MOCK_EXECUTION=false
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_REGION=us-east5
# ENVIRONMENT=production
# DATABASE_PATH=/data/hermes.db
# OUTPUT_BASE_PATH=/output
# HOST=0.0.0.0
# PORT=8000
# RELOAD=false
